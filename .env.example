# ============ Airflow ============
AIRFLOW_UID=50000
AIRFLOW_GID=0
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme

# SMTP Airflow (optionnel, pour les notifications)
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=

# ============ API ============
# Génère SECRET_KEY avec: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-with-secrets-token_urlsafe-64
API_USERNAME=admin
API_PASSWORD=changeme

# ============ Postgres ============
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mlflow

# ============ MongoDB ============
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=MAR25_CMLOPS_RAKUTEN
