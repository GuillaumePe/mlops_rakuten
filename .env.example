# ============ Airflow ============
AIRFLOW_UID=50000
AIRFLOW_GID=0
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme

# SMTP Airflow (optionnel, pour les notifications)
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=

# ============ API ============
# Génère SECRET_KEY avec: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-with-secrets-token_urlsafe-64
API_USERNAME=admin
API_PASSWORD=changeme

# ============ Postgres (MLflow backend) ============
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mlflow

# ============ MongoDB Atlas ============
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://changeme:changeme@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=MAR25_CMLOPS_RAKUTEN

# ============ Cloudflare R2 (DVC remote) ============
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=rakuten-mlops-dvc

# ============ Cloud GPU provider (RunPod) ============
CLOUD_PROVIDER=runpod
RUNPOD_API_KEY=changeme
RUNPOD_VOLUME_ID=
RUNPOD_VOLUME_MOUNT_PATH=/workspace/cache

# ============ GitHub Container Registry (image trainer) ============
# Token avec scope write:packages, généré sur https://github.com/settings/tokens
GITHUB_USER=changeme
GHCR_TOKEN=changeme


# ============ TAILSCALE ============
TAILSCALE_AUTHKEY=tskey-auth-XXX...   # la clé pod : reusable=true, ephemeral=true, preauthorized=true
IP_Tailscale=